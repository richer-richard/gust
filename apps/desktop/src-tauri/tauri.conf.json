{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gust",
  "version": "0.1.0",
  "identifier": "com.gust.sim",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build:web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Gust",
        "width": 1600,
        "height": 980,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png", "icons/icon.icns"],
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
